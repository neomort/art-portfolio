// Deno Deploy Edge Function: rename-organization
// Uses Supabase admin client with service role key to bypass RLS

import 'https://deno.land/std@0.224.0/dotenv/load.ts'
import { createClient } from 'npm:@supabase/supabase-js@2.39.3'

type ErrorResponse = { 
  error: string; 
  detail?: string;
  message?: string;
  requestId?: string;
}

const corsHeaders = {
  'Access-Control-Allow-Origin': '*',
  'Access-Control-Allow-Headers': 'authorization, x-client-info, apikey, content-type',
  'Access-Control-Allow-Methods': 'POST, OPTIONS',
}

function jsonResponse(body: unknown, status = 200, headers: Record<string, string> = {}) {
  return new Response(JSON.stringify(body), {
    status,
    headers: { 
      'Content-Type': 'application/json', 
      ...corsHeaders,
      ...headers 
    },
  })
}

async function getUserFromAuth(req: Request): Promise<{ userId: string } | null> {
  try {
    const auth = req.headers.get('authorization') || req.headers.get('Authorization')
    console.log('Auth header:', auth ? 'present' : 'missing')
    
    if (!auth || !auth.toLowerCase().startsWith('bearer ')) {
      console.log('No or invalid auth header')
      return null
    }
    
    const token = auth.split(' ')[1]
    console.log('Token found, length:', token?.length || 0)
    
    let supabaseUrl = Deno.env.get('SUPABASE_URL') || ''
    console.log('Supabase URL from env:', supabaseUrl ? 'present' : 'missing')
    
    if (!supabaseUrl) {
      try {
        const u = new URL(req.url)
        supabaseUrl = `${u.protocol}//${u.host}`
        console.log('Using URL from request:', supabaseUrl)
      } catch (_e) {
      }
    }
    
    const anonKey = Deno.env.get('SUPABASE_ANON_KEY')
    const adminHeaders = {
      'Authorization': `Bearer ${token}`,
      'apikey': anonKey,
    };
    
    const res = await fetch(`${supabaseUrl}/auth/v1/user`, {
      headers: adminHeaders
    });
    
    if (!res.ok) {
      console.error('Failed to verify token:', await res.text());
      return null;
    }
    
    const user = await res.json();
    return user?.id || null;
  } catch (error) {
    console.error('Error verifying token:', error);
    return null;
  }
}

// Initialize Supabase admin client with RLS bypass
function createAdminClient() {
  const supabaseUrl = Deno.env.get('SUPABASE_URL')
  const serviceKey = Deno.env.get('SUPABASE_SERVICE_ROLE_KEY')
  
  if (!supabaseUrl || !serviceKey) {
    throw new Error('Missing required environment variables')
  }
  
  return createClient(supabaseUrl, serviceKey, {
    auth: {
      autoRefreshToken: false,
      persistSession: false,
      detectSessionInUrl: false
    },
    global: {
      headers: {
        'x-supabase-service-role': serviceKey
      }
    }
  })
}

export const handler = async (req: Request): Promise<Response> => {
  const requestId = crypto.randomUUID()
  
  const log = (message: string, data: Record<string, unknown> = {}) => {
    console.log(JSON.stringify({
      requestId,
      timestamp: new Date().toISOString(),
      message,
      ...data
    }))
  }
  
  try {
    log('Request received', {
      method: req.method,
      url: req.url
    })

    // Handle CORS preflight
    if (req.method === 'OPTIONS') {
      log('Handling OPTIONS request')
      return new Response('ok', { headers: corsHeaders })
    }

    // Only allow POST requests
    if (req.method !== 'POST') {
      log('Method not allowed', { method: req.method })
      return jsonResponse({ 
        error: 'method_not_allowed',
        message: 'Only POST requests are allowed',
        requestId
      }, 405)
    }

    // Initialize admin client with RLS bypass
    const admin = createAdminClient()
    
    // Get auth header
    const authHeader = req.headers.get('authorization') || req.headers.get('Authorization') || ''
    const token = authHeader.split(' ')[1]
    
    if (!token) {
      log('No authorization token provided')
      return jsonResponse({
        error: 'unauthorized',
        message: 'Missing authorization token',
        requestId
      }, 401)
    }

    try {
      // 1. Verify the JWT token
      const { data: { user }, error: authError } = await admin.auth.getUser(token)
      
      if (authError || !user) {
        log('Invalid or expired token', { error: authError?.message })
        return jsonResponse({
          error: 'unauthorized',
          message: 'Invalid or expired token',
          requestId
        }, 401)
      }
      
      log('User authenticated', { userId: user.id })
      
      // 2. Parse request body
      let body: { organizationId?: string; newName?: string }
      try {
        body = await req.json()
      } catch (e) {
        log('Invalid JSON body', { error: String(e) })
        return jsonResponse({
          error: 'invalid_request',
          message: 'Invalid JSON body',
          requestId
        }, 400)
      }
      
      const { organizationId, newName } = body
      
      if (!organizationId || !newName) {
        log('Missing required fields', { organizationId, newName })
        return jsonResponse({
          error: 'invalid_request',
          message: 'Missing required fields: organizationId and newName are required',
          requestId
        }, 400)
      }
      
      // 3. Get the organization
      const { data: organization, error: orgError } = await admin
        .from('organizations')
        .select('*')
        .eq('id', organizationId)
        .single()
        
      if (orgError || !organization) {
        log('Organization not found', { error: orgError?.message })
        return jsonResponse({
          error: 'not_found',
          message: 'Organization not found',
          requestId
        }, 404)
      }
      
      // 4. Update the organization name
      const { data: updatedOrg, error: updateError } = await admin
        .from('organizations')
        .update({ 
          name: newName,
          updated_at: new Date().toISOString()
        })
        .eq('id', organizationId)
        .select()
        .single()
        
      if (updateError) {
        log('Failed to update organization', { error: updateError.message })
        return jsonResponse({
          error: 'update_failed',
          message: 'Failed to update organization',
          detail: updateError.message,
          requestId
        }, 500)
      }
      
      log('Organization updated successfully', { organizationId, newName })
      
      // 5. Return the updated organization
      return jsonResponse({
        success: true,
        organization: updatedOrg,
        requestId
      })
      
    } catch (error) {
      log('Unexpected error', { error: String(error) })
      return jsonResponse({
        error: 'internal_server_error',
        message: 'An unexpected error occurred',
        requestId
      }, 500)
    }
      
      if (!updateRes.ok) {
        const errorText = await updateRes.text().catch(() => 'Failed to read error');
        log('Error updating organization', {
          status: updateRes.status,
          error: errorText,
        });
        return jsonResponse({
          error: 'update_failed',
          message: 'Failed to update organization',
          requestId,
          detail: errorText,
        }, 500);
      }
      
      log('Organization updated successfully', { orgId, newName: name });
      
      // 6. Return success response with the updated organization
      const updatedOrg = await updateRes.json();
      return jsonResponse({
        success: true,
        organization: updatedOrg[0],
        requestId,
      });
      
    } catch (error) {
      log('Unexpected error in handler', {
        error: String(error),
        stack: error instanceof Error ? error.stack : undefined,
      });
      return jsonResponse({
        error: 'internal_server_error',
        message: 'An unexpected error occurred',
        requestId,
      }, 500);
    }
  } catch (error) {
    console.error('Unexpected error in handler:', error);
    return jsonResponse({
      error: 'internal_server_error',
      message: 'An unexpected error occurred',
      requestId: 'unknown',
    }, 500);
