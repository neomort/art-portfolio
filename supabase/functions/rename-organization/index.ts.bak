        return jsonResponse({
          error: 'profile_requires_update',
          detail: 'Your profile needs to be updated',
          requires_update: true
        }, 400)
      }
    }

    let orgId = organizationId || profile.primary_organization_id

    // 5. Find or create organization if needed
    if (!orgId) {
      // Try to find by name (case-insensitive)
      const { data: existingOrg, error: findError } = await admin
        .from('organizations')
        .select('id')
        .ilike('name', name)
        .maybeSingle()

      if (findError) {
        return jsonResponse({ 
          error: 'org_lookup_failed', 
          detail: findError.message 
        }, 500)
      }

      if (existingOrg) {
        orgId = existingOrg.id
      } else {
        // Create new organization
        const { data: newOrg, error: createError } = await admin
          .from('organizations')
          .insert({ name })
