{
  "compilerOptions": {
    "lib": [
      "deno.window",
      "deno.ns",
      "dom",
      "dom.iterable"
    ],
    "strict": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "options": {
      "lineWidth": 100,
      "indentWidth": 2,
      "singleQuote": true,
      "useTabs": false
    }
  }
}
