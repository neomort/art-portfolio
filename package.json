{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "art-portfolio",
  "private": true,
  "version": "0.1.0",
  "description": "Personal art portfolio platform built with React, Supabase, and Vite",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/select-robots.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "build": "vite build",
    "postbuild": "npm run generate:sitemap || true",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "jest --config=jest.config.mjs",
    "test:unit": "jest --config=jest.config.mjs",
    "test:unit:watch": "jest --config=jest.config.mjs --watch",
    "test:unit:coverage": "jest --config=jest.config.mjs --coverage",
    "test:visual": "if [ -z \"$PERCY_TOKEN\" ]; then npm run test:visual:plain; else percy exec -- npx playwright test tests/visual --reporter=list; fi",
    "test:visual:plain": "npx playwright test tests/visual --reporter=list",
    "test:visual:update": "if [ -z \"$PERCY_TOKEN\" ]; then echo 'Set PERCY_TOKEN to update visuals' && exit 1; else percy exec --update-visuals -- npx playwright test tests/visual --reporter=list; fi",
    "test:visual:ci": "if [ -z \"$PERCY_TOKEN\" ]; then npm run test:visual:plain; else percy exec -t 300 -- npx playwright test tests/visual --reporter=list --workers=1; fi",
    "test:all": "npm run test:unit && npm run test:visual",
    "migrate:users": "node scripts/migrate-users.mjs",
    "db:guard:prod": "if [ -z \"$DATABASE_URL\" ]; then echo 'Set DATABASE_URL env var' && exit 1; fi; psql \"$DATABASE_URL\" -X -t -A -v ON_ERROR_STOP=1 -f scripts/check-security-definer-search-path.sql | tee /dev/stderr | awk 'NF{found=1} END{exit found?1:0}'",
    "db:guard:demo": "if [ -z \"$DEMO_DATABASE_URL\" ]; then echo 'Set DEMO_DATABASE_URL env var' && exit 1; fi; psql \"$DEMO_DATABASE_URL\" -X -t -A -v ON_ERROR_STOP=1 -f scripts/check-security-definer-search-path.sql | tee /dev/stderr | awk 'NF{found=1} END{exit found?1:0}'",
    "db:guard": "npm run db:guard:prod && npm run db:guard:demo"
  },
  "dependencies": {
    "@daypilot/daypilot-lite-react": "^4.4.0",
    "@internationalized/date": "^3.8.2",
    "@supabase/supabase-js": "^2.57.4",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@tiptap/extension-code-block-lowlight": "^3.4.1",
    "@tiptap/extension-color": "^3.4.1",
    "@tiptap/extension-highlight": "^3.4.1",
    "@tiptap/extension-image": "^3.4.1",
    "@tiptap/extension-link": "^3.4.1",
    "@tiptap/extension-placeholder": "^3.4.1",
    "@tiptap/extension-table": "^3.4.1",
    "@tiptap/extension-table-cell": "^3.4.1",
    "@tiptap/extension-table-header": "^3.4.1",
    "@tiptap/extension-table-row": "^3.4.1",
    "@tiptap/extension-task-item": "^3.4.1",
    "@tiptap/extension-task-list": "^3.4.1",
    "@tiptap/extension-text-align": "^3.4.1",
    "@tiptap/extension-text-style": "^3.4.1",
    "@tiptap/extension-underline": "^3.4.1",
    "@tiptap/react": "^3.4.1",
    "@tiptap/starter-kit": "^3.4.1",
    "@types/file-saver": "^2.0.7",
    "@types/react-datepicker": "^6.2.0",
    "browser-image-compression": "^2.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^16.6.1",
    "easymde": "^2.18.0",
    "file-saver": "^2.0.5",
    "form-data": "^4.0.4",
    "leaflet": "^1.9.4",
    "lowlight": "^3.3.0",
    "lucide-react": "^0.544.0",
    "marked": "^16.1.1",
    "node-fetch": "^3.3.2",
    "pg": "^8.16.3",
    "rc-slider": "^10.5.0",
    "react": "^18.3.1",
    "react-aria": "^3.42.0",
    "react-aria-components": "^1.11.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.8",
    "react-icons": "^5.5.0",
    "react-leaflet": "^4.2.1",
    "react-router": "^6.30.3",
    "react-router-dom": "^6.30.3",
    "react-simplemde-editor": "^5.2.0",
    "survey-core": "^2.3.8",
    "survey-creator-core": "^2.3.8",
    "survey-creator-react": "^2.3.8",
    "survey-react-ui": "^2.3.8",
    "tailwind-merge": "^3.3.1",
    "ts-node": "^10.9.2",
    "tz-lookup": "^6.1.25",
    "winston": "^3.3.1"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/plugin-transform-modules-commonjs": "^7.27.1",
    "@babel/plugin-transform-runtime": "^7.28.0",
    "@babel/preset-env": "^7.28.0",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@eslint/js": "^9.9.1",
    "@percy/cli": "^1.30.6",
    "@percy/playwright": "^1.0.9",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^28.1.6",
    "@types/leaflet": "^1.9.20",
    "@types/lodash": "^4.17.20",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/tz-lookup": "^6.1.2",
    "@typescript-eslint/eslint-plugin": "^8.27.0",
    "@typescript-eslint/parser": "^8.27.0",
    "@typescript-eslint/utils": "^8.27.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitejs/plugin-react-swc": "^3.11.0",
    "autoprefixer": "^10.4.17",
    "babel-jest": "^29.7.0",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "baseline-browser-mapping": "^2.9.11",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^15.9.0",
    "history": "^5.3.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "typescript-eslint": "^8.27.0",
    "vite": "^7.1.11",
    "vite-plugin-node-polyfills": "^0.24.0"
  },
  "overrides": {
    "test-exclude": "^7.0.1",
    "glob": "^10.4.4",
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "json5": "^1.0.2",
    "merge": "^2.1.1",
    "tough-cookie": "^4.1.3",
    "simple-swizzle": "^0.2.2",
    "node-notifier": "^10.0.1"
  }
}
